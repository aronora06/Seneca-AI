# Copy to .env and fill in real values. See docs/setup.md.
# Only variables starting with VITE_ are exposed to the browser.

# ── Dev bypass ─────────────────────────────────────────────────────────────
# Set to true while you're hacking on Seneca locally. The web app will skip
# Supabase entirely, sign you in as a fake "dev" user, and go straight into
# the app. Must match DEV_BYPASS_AUTH on the API side.
VITE_DEV_BYPASS_AUTH=true

# ── Backend ────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8787

# ── Diagrams tab (draw.io embed) ─────────────────────────────────────────
# VITE_DRAWIO_EMBED_URL=https://embed.diagrams.net

# ── Supabase (only needed when VITE_DEV_BYPASS_AUTH is false) ──────────────
# VITE_SUPABASE_URL=https://zrfeaygvqztuxmknehoq.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
