# Copy to .env and fill in real values. See docs/setup.md.

PORT=8787
WEB_ORIGIN=http://localhost:5173

# ── Dev bypass ─────────────────────────────────────────────────────────────
# Set to true while you're hacking on Seneca locally. The API will skip JWT
# validation, attach a stable fake "dev" user, and use an in-memory session
# store. You don't need a Supabase project in this mode — only an Anthropic
# key is required.
#
# Set this to false for real deployments. The web side has its own flag
# (VITE_DEV_BYPASS_AUTH) that must match.
DEV_BYPASS_AUTH=true

# ── Anthropic (always required) ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_TEXT_MODEL=claude-sonnet-4-6
ANTHROPIC_VISION_MODEL=claude-opus-4-7

# ── Tavily (optional; powers web_search in the Web tab) ────────────────────
# Without this, the Web tab still loads and `web_navigate` works, but
# `web_search` returns a friendly "configure Tavily" error. Get a free key
# at https://app.tavily.com.
# TAVILY_API_KEY=tvly-...

# ── Voyage AI (optional; powers semantic document_search) ──────────────────
# Without this, `document_search` falls back to a naive substring scan of
# extracted PDF text — still works, just won't catch paraphrased queries.
# Free tier at https://www.voyageai.com. Default model is voyage-3-large
# (1024-dim); changing the dim requires a schema migration.
# VOYAGE_API_KEY=pa-...
# VOYAGE_MODEL=voyage-3-large

# ── Supabase (only needed when DEV_BYPASS_AUTH is false) ───────────────────
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
